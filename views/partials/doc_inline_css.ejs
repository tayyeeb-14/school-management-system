
/* Inline document CSS used for Puppeteer PDF rendering */
.doc-body-wrapper{width:100%;display:flex;justify-content:center;padding:18px;background:#fff}
body.document{font-family: 'Segoe UI', Roboto, Arial, Helvetica, sans-serif; color:#111; margin:0; padding:0; background:#fff}
.doc-container{width:760px; max-width:95%; margin:0 auto; padding:20px 22px; border:1px solid #e9e9e9; background:#fff; box-sizing:border-box}
.doc-header{display:flex;flex-direction:column;align-items:center;border-bottom:1px solid #eee;padding-bottom:10px;margin-bottom:14px;text-align:center}
.doc-header > div{width:100%;text-align:center}
.logo{display:block;margin:6px auto 8px auto;height:48px;max-width:220px;width:auto}
.school-name{font-weight:700;font-size:18px}
.doc-title{font-size:15px;color:#333;margin-top:6px}
.meta{font-size:12px;color:#666}
.section{margin:12px 0; font-size:13px; line-height:1.4; color:#222}
.marks{width:100%;border-collapse:collapse;margin-top:12px}
.marks th,.marks td{border:1px solid #dcdcdc;padding:10px 8px;font-size:14px}
.marks th{background:#fafafa;text-align:left}
.marks td:nth-child(2),.marks td:nth-child(3){text-align:center}
.marks th{background:#f7f7f7}
.totals{margin-top:10px;font-weight:700;font-size:15px}
.signature-row{display:flex;justify-content:space-between;margin-top:34px}
.signature{width:45%;text-align:center;font-size:13px;color:#222}
.id-card{width:340px;padding:12px;border:1px solid #dcdcdc;background:#fafafa}
.id-photo{width:110px;height:140px;object-fit:cover;border:1px solid #ddd;border-radius:4px}
.photo-block{width:120px;height:150px;display:block;overflow:hidden;border:1px solid #e6e6e6;border-radius:4px}
.photo-block img{width:100%;height:100%;object-fit:cover;display:block}
.centered{text-align:center !important}
.doc-header .centered img{display:block;margin:0 auto}
.doc-header .centered .school-name,.doc-header .centered .doc-title{display:block}
.footer{margin-top:18px;font-size:12px;color:#666;display:flex;justify-content:space-between}

/* Certificate */
.marks th:first-child{width:60%}
.marks td:first-child{width:60%}
.certificate{border:8px solid #f5f5f5;padding:60px 48px;background:#fff}
.certificate h1{font-size:30px;margin:6px 0 10px 0;letter-spacing:0.6px}
.certificate h2{font-size:20px;margin:8px 0;color:#222}
.certificate .school-name{font-size:16px;margin-bottom:6px}
.certificate p{font-size:15px;color:#333}
.certificate .center-block{max-width:760px;margin:0 auto;text-align:center}

.doc-container.centered{max-width:880px}

@media print{
  body.document{background:#fff}
  .doc-container{box-shadow:none;border:none;margin:0;padding:12mm}
}
