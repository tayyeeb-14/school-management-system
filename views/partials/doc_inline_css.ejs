
/* Inline document CSS used for Puppeteer PDF rendering */
.doc-body-wrapper{width:100%;display:flex;justify-content:center;padding:18px;background:#fff}
body.document{font-family: 'Segoe UI', Roboto, Arial, Helvetica, sans-serif; color:#111; margin:0; padding:0; background:#fff}
.doc-container{width:760px; max-width:95%; margin:0; padding:24px; border:1px solid #e9e9e9; background:#fff}
.doc-header{display:flex;gap:12px;align-items:center;border-bottom:1px solid #eee;padding-bottom:12px;margin-bottom:16px}
.doc-header > div{flex:1;text-align:center}
.logo{height:72px;margin-right:16px}
.school-name{font-weight:700;font-size:22px}
.doc-title{font-size:18px;color:#333;margin-top:6px}
.meta{font-size:13px;color:#666}
.section{margin:14px 0; font-size:14px; line-height:1.45}
.marks{width:100%;border-collapse:collapse;margin-top:12px}
.marks th,.marks td{border:1px solid #dcdcdc;padding:12px 10px;text-align:left;font-size:15px}
.marks th{background:#f7f7f7}
.totals{margin-top:10px;font-weight:700;font-size:15px}
.signature-row{display:flex;justify-content:space-between;margin-top:40px}
.signature{width:45%;text-align:center;font-size:14px}
.id-card{width:320px;padding:14px;border:1px solid #dcdcdc;background:#fafafa}
.id-photo{width:110px;height:140px;object-fit:cover;border:1px solid #ddd}
.centered{text-align:center}
.footer{margin-top:18px;font-size:12px;color:#666;display:flex;justify-content:space-between}

/* Certificate */
.certificate{border:12px solid #f5f5f5;padding:48px}
.certificate h1{font-size:34px;margin-bottom:6px}
.certificate h2{font-size:24px;margin:8px 0}

.doc-container.centered{max-width:880px}

@media print{
  body.document{background:#fff}
  .doc-container{box-shadow:none;border:none;margin:0;padding:12mm}
}
