<div class="container min-vh-100 d-flex align-items-center justify-content-center" data-page="forgot-reset">
    <div class="row w-100 justify-content-center">
        <div class="col-12 col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-header py-4 text-center" style="background: linear-gradient(90deg,var(--brand),var(--brand-600)); color: #fff; border-radius: .5rem .5rem 0 0;">
                    <h4 class="mb-0" id="pageTitle">Reset Password</h4>
                    <small class="d-block opacity-75">Securely reset your account password</small>
                </div>
                <div class="card-body p-4">
                    <div id="messageAlert"></div>

                    <form id="resetForm">
                        <!-- STEP 1: Email Input -->
                        <div id="step1" class="step-section">
                            <div class="mb-3">
                                <label for="email" class="form-label">Enter your email</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white"><i class="fas fa-envelope text-muted"></i></span>
                                    <input type="email" class="form-control" id="email" name="email" placeholder="your@email.com" required>
                                </div>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-primary" id="sendOtpBtn">
                                    <span id="sendOtpText">Send OTP</span>
                                    <span id="sendOtpSpinner" class="spinner-border spinner-border-sm d-none ms-2" role="status" aria-hidden="true"></span>
                                </button>
                            </div>
                        </div>

                        <!-- STEP 2: OTP Input -->
                        <div id="step2" class="step-section d-none">
                            <div class="alert alert-info" role="alert">
                                <small><i class="fas fa-info-circle"></i> OTP sent to <strong id="emailDisplay"></strong></small>
                            </div>

                            <div class="mb-3">
                                <label for="otp" class="form-label">Enter 6-digit OTP</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white"><i class="fas fa-shield-alt text-muted"></i></span>
                                    <input type="text" class="form-control" id="otp" name="otp" placeholder="000000" maxlength="6" required>
                                </div>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-primary" id="verifyOtpBtn">
                                    <span id="verifyOtpText">Verify OTP</span>
                                    <span id="verifyOtpSpinner" class="spinner-border spinner-border-sm d-none ms-2" role="status" aria-hidden="true"></span>
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm mt-2" id="resendOtpBtn">
                                    Resend OTP
                                </button>
                            </div>
                        </div>

                        <!-- STEP 3: New Password Input -->
                        <div id="step3" class="step-section d-none">
                            <div class="alert alert-success" role="alert">
                                <small><i class="fas fa-check-circle"></i> OTP verified! Now set your new password.</small>
                            </div>

                            <div class="mb-3">
                                <label for="newPassword" class="form-label">New Password</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white"><i class="fas fa-lock text-muted"></i></span>
                                    <input type="password" class="form-control" id="newPassword" name="newPassword" required onkeyup="checkPasswordStrength(this.value)">
                                </div>
                                <div class="progress mt-2" style="height: 6px;">
                                    <div id="password-strength" class="progress-bar" role="progressbar"></div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="confirmPassword" class="form-label">Confirm New Password</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white"><i class="fas fa-lock text-muted"></i></span>
                                    <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
                                </div>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-primary" id="resetPasswordBtn">
                                    <span id="resetPasswordText">Reset Password</span>
                                    <span id="resetPasswordSpinner" class="spinner-border spinner-border-sm d-none ms-2" role="status" aria-hidden="true"></span>
                                </button>
                            </div>
                        </div>

                        <!-- STEP 4: Success -->
                        <div id="step4" class="step-section d-none text-center">
                            <div class="mb-4">
                                <i class="fas fa-check-circle text-success" style="font-size: 3rem;"></i>
                            </div>
                            <h4>Password Reset Successfully!</h4>
                            <p class="text-muted mb-4">Your password has been updated. You can now login with your new password.</p>
                            
                        </div>
                    </form>
                    
                    <div class="text-center mt-4">
                        <p><a href="/auth/login" class="btn btn-outline-primary">Back to Login</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- page-specific script will be loaded by /js/main.js loader -->
