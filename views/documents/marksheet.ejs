<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Marksheet - <%= student.userId.name %></title>
  <style>
    <%- include('../partials/doc_inline_css') %>
  </style>
  </head>
<body class="document">
  <div class="doc-body-wrapper">
  <div class="doc-container">
    <div class="doc-header centered">
      <div>
        <img class="logo" src="<%= logoDataUri %>" alt="Logo"/>
        <div class="school-name">Your School Name</div>
        <div class="doc-title">Marksheet</div>
        <div class="meta">Academic session: 2025-2026</div>
      </div>
    </div>

    <div class="section">
      <strong>Student:</strong> <%= student.userId.name %><br/>
      <strong>Class:</strong> <%= student.classId ? student.classId.name : '' %> &nbsp;&nbsp; <strong>Roll No:</strong> <%= student.rollNo %>
    </div>

    <% const result = locals.marksheetData || null; %>
    <% const examColumns = ['UT1', 'UT2', 'HALF_YEARLY', 'FINAL']; %>
    <div class="section">
      <table class="marks">
        <thead>
          <tr>
            <th>Subject</th>
            <th>UT1</th>
            <th>UT2</th>
            <th>Half Yearly</th>
            <th>Final</th>
            <th>Final %</th>
            <th>Grade</th>
          </tr>
        </thead>
        <tbody>
          <% if (result && result.rows && result.rows.length > 0) { %>
            <% result.rows.forEach((row) => { %>
              <tr>
                <td><%= row.subject %></td>
                <% examColumns.forEach((examKey) => { %>
                  <% const exam = row.exams[examKey]; %>
                  <td>
                    <% if (exam && exam.outOf) { %>
                      <%= exam.marks %>/<%= exam.outOf %>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                <% }) %>
                <td><%= Number(row.finalPercentage || 0).toFixed(2) %>%</td>
                <td><%= row.grade %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <% const subjects = (student.subjects && student.subjects.length) ? student.subjects : ['Mathematics','English','Science','History']; %>
            <% subjects.forEach((subject) => { %>
              <tr>
                <td><%= subject %></td>
                <td>-</td>
                <td>-</td>
                <td>-</td>
                <td>-</td>
                <td>0.00%</td>
                <td>F</td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
      <div class="totals">
        Overall Percentage:
        <%= result ? Number(result.overallPercentage || 0).toFixed(2) : '0.00' %>%
        &nbsp;&nbsp; Grade:
        <strong><%= result ? result.overallGrade : 'F' %></strong>
      </div>
    </div>

    <div class="signature-row">
      <div class="signature">__________________<br/>Class Teacher</div>
      <div class="signature">__________________<br/>Principal</div>
    </div>

    <div class="footer">
      <div>Generated on <%= new Date().toLocaleDateString() %></div>
      <div>Signature of authority</div>
    </div>
  </div>
  </div>
</body>
</html>
