<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - MySchool Portal</title>
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Inter Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="/css/style.css" rel="stylesheet">
    <!-- Dashboard specific CSS -->
    <link href="/css/dashboard.css" rel="stylesheet">
    <meta name="theme-color" content="#4f46e5">
</head>
<body class="dashboard-body">
    <div class="dashboard-wrapper">

        <!-- Sidebar -->
        <div class="offcanvas-lg offcanvas-start dashboard-sidebar" id="dashboardSidebar">
            <div class="offcanvas-header d-lg-none">
                <h5 class="offcanvas-title">Menu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#dashboardSidebar"></button>
            </div>
            <div class="offcanvas-body p-0">
                <div class="dashboard-sidebar-content">
                    <!-- User Profile Summary -->
                    <div class="text-center p-4">
                    <% const avatarSrc = (user && user.photo && user.photo !== 'default.jpg') ? ('/uploads/images/' + user.photo) : '/img/testimonial1.jpg'; %>
                    <img src="<%= avatarSrc %>" class="rounded-circle mb-3" alt="Profile Photo" width="100">
                        <h5 class="mb-1"><%= user.name %></h5>
                        <p class="text-muted"><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></p>
                    </div>

                    <!-- Navigation Menu -->
                    <%- include(`../partials/dashboard-${user.role}-menu`) %>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="dashboard-main">
            <!-- Top Navigation -->
            <nav class="navbar navbar-expand navbar-light bg-white shadow-sm mb-4 dashboard-nav">
                    <div class="container-fluid">
                        <button class="btn btn-primary d-lg-none me-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#dashboardSidebar" aria-controls="dashboardSidebar" aria-label="Open menu">
                        <i class="fas fa-bars"></i>
                        </button>
                        <h4 class="mb-0"><%= title %></h4>
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/profile">Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/auth/logout">Logout</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Page Content -->
            <div class="container-fluid pb-4">
                <%- include('../partials/messages') %>
                <%- body %>
            </div>
        </div>
    </div>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Moment.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Custom JavaScript -->
    <script src="/js/main.js"></script>
    <script src="/js/dashboard.js"></script>
</body>
</html>