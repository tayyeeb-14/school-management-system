<%
const resolvedClassFee = typeof classFee !== 'undefined' ? classFee : null;
const resolvedStandardMonthlyFee = typeof standardMonthlyFee !== 'undefined' ? Number(standardMonthlyFee || 0) : 0;
const resolvedSummary = (typeof summary !== 'undefined' && summary) ? summary : {
    standardMonthlyFee: resolvedStandardMonthlyFee,
    totalPaid: 0,
    outstandingBalance: 0,
    overdueAmount: 0,
    creditAmount: 0,
    unpaidDuesCount: 0
};
const resolvedDueEntries = (typeof dueEntries !== 'undefined' && Array.isArray(dueEntries)) ? dueEntries : [];
const resolvedSortedPayments = (typeof sortedPayments !== 'undefined' && Array.isArray(sortedPayments)) ? sortedPayments : [];
const resolvedMonthOptions = (typeof monthOptions !== 'undefined' && Array.isArray(monthOptions)) ? monthOptions : [];
const unpaidDueEntries = resolvedDueEntries.filter((entry) => !entry.isPaid);
const feeBreakdown = resolvedClassFee && resolvedClassFee.fees ? resolvedClassFee.fees : [];
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
        <h3 class="mb-1">Fee Management - <%= student.userId.name %></h3>
        <p class="text-muted mb-0">Manage monthly dues, record payments, and download invoices from one place.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a href="/admin/students" class="btn btn-secondary">Back to Students</a>
        <% if (student.classId) { %>
            <a href="/admin/classes/<%= student.classId._id %>/fees/collect-payment" class="btn btn-success">
                <i class="fas fa-layer-group me-1"></i> Class-Wide Action
            </a>
        <% } %>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Student Overview</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <small class="text-muted d-block">Student</small>
                <strong><%= student.userId.name %></strong>
            </div>
            <div class="col-md-2">
                <small class="text-muted d-block">Roll No</small>
                <strong><%= student.rollNo %></strong>
            </div>
            <div class="col-md-2">
                <small class="text-muted d-block">Class</small>
                <strong><%= student.classId ? student.classId.name : 'N/A' %></strong>
            </div>
            <div class="col-md-3">
                <small class="text-muted d-block">Email</small>
                <strong><%= student.userId.email %></strong>
            </div>
            <div class="col-md-2">
                <small class="text-muted d-block">Standard Monthly Fee</small>
                <strong><%= resolvedStandardMonthlyFee.toFixed(2) %></strong>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-2">
        <div class="card bg-primary text-white h-100">
            <div class="card-body text-center">
                <small class="text-white-50 d-block mb-2">Monthly Fee</small>
                <h4 class="mb-0"><%= Number(resolvedSummary.standardMonthlyFee || 0).toFixed(2) %></h4>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="card bg-success text-white h-100">
            <div class="card-body text-center">
                <small class="text-white-50 d-block mb-2">Total Paid</small>
                <h4 class="mb-0"><%= Number(resolvedSummary.totalPaid || 0).toFixed(2) %></h4>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="card bg-danger text-white h-100">
            <div class="card-body text-center">
                <small class="text-white-50 d-block mb-2">Outstanding</small>
                <h4 class="mb-0"><%= Number(resolvedSummary.outstandingBalance || 0).toFixed(2) %></h4>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="card bg-warning text-dark h-100">
            <div class="card-body text-center">
                <small class="text-muted d-block mb-2">Overdue</small>
                <h4 class="mb-0"><%= Number(resolvedSummary.overdueAmount || 0).toFixed(2) %></h4>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="card bg-info text-white h-100">
            <div class="card-body text-center">
                <small class="text-white-50 d-block mb-2">Credit</small>
                <h4 class="mb-0"><%= Number(resolvedSummary.creditAmount || 0).toFixed(2) %></h4>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="card bg-dark text-white h-100">
            <div class="card-body text-center">
                <small class="text-white-50 d-block mb-2">Open Dues</small>
                <h4 class="mb-0"><%= Number(resolvedSummary.unpaidDuesCount || 0) %></h4>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-7">
        <div class="card h-100">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Record Payment</h5>
            </div>
            <div class="card-body">
                <form action="/admin/students/<%= student._id %>/fees/add-payment" method="POST">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Month</label>
                            <select name="month" class="form-select" required>
                                <option value="">Choose fee month</option>
                                <% resolvedMonthOptions.forEach((month) => { %>
                                    <option value="<%= month %>"><%= month %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Amount</label>
                            <input
                                type="number"
                                step="0.01"
                                min="0"
                                name="amount"
                                class="form-control"
                                value="<%= resolvedStandardMonthlyFee ? resolvedStandardMonthlyFee.toFixed(2) : '' %>"
                                placeholder="0.00"
                                required
                            >
                        </div>
                        <div class="col-12">
                            <label class="form-label">Apply Against Due</label>
                            <select name="monthlyDueId" class="form-select">
                                <option value="">Auto-match by selected month</option>
                                <% unpaidDueEntries.forEach((entry) => { %>
                                    <option value="<%= entry.due._id %>">
                                        <%= entry.due.month %> - Pending <%= entry.pendingAmount.toFixed(2) %>
                                    </option>
                                <% }) %>
                            </select>
                            <small class="text-muted">If you choose an open due, the payment will be allocated there first.</small>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea
                                name="description"
                                rows="3"
                                class="form-control"
                                placeholder="Optional note, receipt detail, or collection remark"
                            ></textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <small class="text-muted">Invoice will open immediately after saving the payment.</small>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-plus-circle me-1"></i> Save Payment
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-5">
        <div class="card mb-4">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">Create / Update Monthly Due</h5>
            </div>
            <div class="card-body">
                <form action="/admin/students/<%= student._id %>/fees/add-monthly-due" method="POST">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Month</label>
                            <select name="month" class="form-select" required>
                                <option value="">Choose due month</option>
                                <% resolvedMonthOptions.forEach((month) => { %>
                                    <option value="<%= month %>"><%= month %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Due Amount</label>
                            <input
                                type="number"
                                step="0.01"
                                min="0"
                                name="dueAmount"
                                class="form-control"
                                value="<%= resolvedStandardMonthlyFee ? resolvedStandardMonthlyFee.toFixed(2) : '' %>"
                                required
                            >
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Due Date</label>
                            <input type="date" name="dueDate" class="form-control" required>
                        </div>
                    </div>

                    <div class="text-end mt-3">
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-calendar-plus me-1"></i> Save Due
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-light">
                <h5 class="mb-0">Fee Settings</h5>
            </div>
            <div class="card-body">
                <form action="/admin/students/<%= student._id %>/fees/update-monthly" method="POST">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Student Monthly Fee</label>
                            <input
                                type="number"
                                step="0.01"
                                min="0"
                                name="monthlyFee"
                                class="form-control"
                                value="<%= Number((fee && fee.monthlyFee) || resolvedStandardMonthlyFee).toFixed(2) %>"
                                required
                            >
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Default Due Amount</label>
                            <input
                                type="number"
                                step="0.01"
                                min="0"
                                name="totalDue"
                                class="form-control"
                                value="<%= Number((fee && fee.totalDue) || resolvedStandardMonthlyFee).toFixed(2) %>"
                                required
                            >
                        </div>
                    </div>

                    <div class="text-end mt-3">
                        <button type="submit" class="btn btn-outline-primary">
                            <i class="fas fa-save me-1"></i> Update Settings
                        </button>
                    </div>
                </form>

                <% if (feeBreakdown.length > 0) { %>
                    <hr>
                    <h6 class="mb-3">Class Fee Breakdown</h6>
                    <div class="list-group list-group-flush">
                        <% feeBreakdown.forEach((item) => { %>
                            <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <div>
                                    <strong><%= item.name %></strong>
                                    <div class="text-muted small text-capitalize"><%= item.frequency %></div>
                                </div>
                                <span class="badge bg-light text-dark border"><%= Number(item.amount).toFixed(2) %></span>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <hr>
                    <p class="text-muted mb-0">No class fee breakdown has been configured yet. You can still manage this student manually.</p>
                <% } %>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Monthly Dues Ledger</h5>
        <span class="badge bg-light text-dark"><%= resolvedDueEntries.length %> entries</span>
    </div>
    <div class="card-body">
        <% if (resolvedDueEntries.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Month</th>
                            <th>Due Amount</th>
                            <th>Paid</th>
                            <th>Pending</th>
                            <th>Due Date</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% resolvedDueEntries.forEach((entry) => { %>
                            <tr class="<%= entry.isOverdue ? 'table-danger' : '' %>">
                                <td><strong><%= entry.due.month %></strong></td>
                                <td><%= Number(entry.due.dueAmount || 0).toFixed(2) %></td>
                                <td><%= Number(entry.due.paidAmount || 0).toFixed(2) %></td>
                                <td><strong><%= entry.pendingAmount.toFixed(2) %></strong></td>
                                <td><%= entry.due.dueDate ? moment(entry.due.dueDate).format('DD MMM, YYYY') : '-' %></td>
                                <td>
                                    <% if (entry.isPaid) { %>
                                        <span class="badge bg-success">Paid</span>
                                    <% } else if (entry.isOverdue) { %>
                                        <span class="badge bg-danger">Overdue</span>
                                    <% } else { %>
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    <% } %>
                                </td>
                                <td>
                                    <form action="/admin/students/<%= student._id %>/fees/monthly-due/<%= entry.due._id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this monthly due?')">
                                        <input type="hidden" name="_method" value="DELETE">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="alert alert-info mb-0">
                <i class="fas fa-info-circle me-1"></i> No monthly dues have been created yet.
            </div>
        <% } %>
    </div>
</div>

<div class="card">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Payment History</h5>
        <span class="badge bg-light text-dark"><%= resolvedSortedPayments.length %> payments</span>
    </div>
    <div class="card-body">
        <% if (resolvedSortedPayments.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Month</th>
                            <th>Amount</th>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% resolvedSortedPayments.forEach((payment) => { %>
                            <tr>
                                <td><strong><%= payment.month %></strong></td>
                                <td><span class="badge bg-success"><%= Number(payment.amount || 0).toFixed(2) %></span></td>
                                <td><small><%= moment(payment.date).format('DD MMM, YYYY') %></small></td>
                                <td>
                                    <% if (payment.collectedFromClass) { %>
                                        <span class="badge bg-primary">Class</span>
                                    <% } else { %>
                                        <span class="badge bg-info text-dark">Manual</span>
                                    <% } %>
                                </td>
                                <td><%= payment.description || '-' %></td>
                                <td class="text-end">
                                    <a href="/admin/students/<%= student._id %>/fees/invoice?paymentId=<%= payment._id %>" class="btn btn-sm btn-outline-primary">
                                        Invoice
                                    </a>
                                    <form action="/admin/students/<%= student._id %>/fees/payment/<%= payment._id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this payment and recalculate the ledger?')">
                                        <input type="hidden" name="_method" value="DELETE">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="alert alert-info mb-0">
                <i class="fas fa-info-circle me-1"></i> No payments have been recorded yet.
            </div>
        <% } %>
    </div>
</div>
