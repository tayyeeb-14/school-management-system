<h3 class="mb-4">Fee Details - <%= student.userId.name %></h3>

<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Student Information</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <p class="mb-1"><strong>Roll No</strong></p>
                <p class="h6"><%= student.rollNo %></p>
            </div>
            <div class="col-md-3">
                <p class="mb-1"><strong>Class</strong></p>
                <p class="h6"><%= student.classId ? student.classId.name : 'N/A' %></p>
            </div>
            <div class="col-md-3">
                <p class="mb-1"><strong>Email</strong></p>
                <p class="h6"><small><%= student.userId.email %></small></p>
            </div>
            <div class="col-md-3">
                <p class="mb-1"><strong>Total Due</strong></p>
                <p class="h6"><span class="badge bg-danger"><%= fee.totalDue || 0 %></span></p>
            </div>
        </div>
    </div>
</div>

<!-- Fee Overview Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h6 class="card-title">Total Paid</h6>
                <h3><%= totalPaid || 0 %></h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-white">
            <div class="card-body text-center">
                <h6 class="card-title">Return Amount</h6>
                <h3><%= Math.max(0, totalPaid - (fee.totalDue || 0)).toFixed(2) %></h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body text-center">
                <h6 class="card-title">Overdue</h6>
                <h3>0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-secondary text-white">
            <div class="card-body text-center">
                <h6 class="card-title">Balance</h6>
                <h3><%= Math.max(0, (fee.totalDue || 0) - totalPaid).toFixed(2) %></h3>
            </div>
        </div>
    </div>
</div>

<!-- Payment History -->
<div class="card">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">📋 Payment History</h5>
    </div>
    <div class="card-body">
        <% if (fee.payments && fee.payments.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Month</th>
                            <th>Amount</th>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% fee.payments.forEach((payment, index) => { %>
                            <tr>
                                <td><strong><%= payment.month %></strong></td>
                                <td><span class="badge bg-success"><%= payment.amount %></span></td>
                                <td><small><%= moment(payment.date).format('DD MMM, YYYY') %></small></td>
                                <td>
                                    <% if (payment.collectedFromClass) { %>
                                        <span class="badge bg-success">Class</span>
                                    <% } else { %>
                                        <span class="badge bg-info">Manual</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (!payment.collectedFromClass) { %>
                                        <form action="/admin/students/<%= student._id %>/fees/payment/<%= payment._id %>?_method=DELETE" method="POST" class="d-inline">
                                            <button class="btn btn-sm btn-danger" onclick="return confirm('Delete this payment?')">Delete</button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="alert alert-info mb-0">
                <i class="fas fa-info-circle"></i> No payments recorded yet.
            </div>
        <% } %>
    </div>
</div>

<div class="mt-4">
    <a href="/admin/students" class="btn btn-secondary">Back to Students</a>
    <% if (student.classId) { %>
        <a href="/admin/classes/<%= student.classId._id %>/fees/collect-payment" class="btn btn-success">
            <i class="fas fa-plus"></i> Class Payment
        </a>
    <% } %>
</div>