<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= `Payment Invoice - ${student.userId.name}` %></title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Arial', sans-serif;
            background-color: #f5f5f5;
            padding: 20px;
        }
        
        .invoice-container {
            width: 210mm;
            height: 297mm;
            background: white;
            margin: 0 auto;
            padding: 40px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        
        .header {
            text-align: center;
            border-bottom: 3px solid #2c3e50;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        
        .header h1 {
            color: #2c3e50;
            font-size: 32px;
            margin-bottom: 10px;
        }
        
        .header p {
            color: #7f8c8d;
            font-size: 14px;
        }
        
        .invoice-number {
            float: right;
            text-align: right;
            margin-bottom: 20px;
        }
        
        .invoice-number p {
            font-size: 12px;
            color: #7f8c8d;
            margin: 5px 0;
        }
        
        .invoice-number .number {
            font-size: 14px;
            font-weight: bold;
            color: #2c3e50;
        }
        
        .student-info {
            margin-bottom: 30px;
            clear: both;
        }
        
        .student-info h3 {
            color: #2c3e50;
            font-size: 16px;
            margin-bottom: 15px;
            border-bottom: 2px solid #ecf0f1;
            padding-bottom: 8px;
        }
        
        .info-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 15px;
        }
        
        .info-item {
            font-size: 14px;
            line-height: 1.8;
        }
        
        .info-item label {
            font-weight: bold;
            color: #2c3e50;
        }
        
        .info-item span {
            color: #34495e;
        }
        
        .payment-details {
            margin: 30px 0;
            padding: 20px;
            background-color: #f8f9fa;
            border-left: 4px solid #27ae60;
            border-radius: 4px;
        }
        
        .payment-details h3 {
            color: #27ae60;
            font-size: 16px;
            margin-bottom: 15px;
        }
        
        .detail-table {
            width: 100%;
            margin-bottom: 15px;
            font-size: 14px;
        }
        
        .detail-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px dotted #bdc3c7;
        }
        
        .detail-row.total {
            border-bottom: 2px solid #27ae60;
            font-weight: bold;
            font-size: 16px;
            padding: 15px 0;
            color: #27ae60;
        }
        
        .detail-row label {
            color: #2c3e50;
        }
        
        .detail-row span {
            color: #34495e;
            text-align: right;
        }
        
        .success-message {
            text-align: center;
            margin: 30px 0;
            padding: 20px;
            background-color: #d5f4e6;
            border: 2px solid #27ae60;
            border-radius: 4px;
        }
        
        .success-message .icon {
            font-size: 40px;
            color: #27ae60;
            margin-bottom: 10px;
        }
        
        .success-message h2 {
            color: #27ae60;
            margin: 10px 0;
            font-size: 24px;
        }
        
        .success-message p {
            color: #16a085;
            font-size: 14px;
        }
        
        .footer {
            margin-top: 40px;
            text-align: center;
            font-size: 12px;
            color: #7f8c8d;
            border-top: 1px solid #ecf0f1;
            padding-top: 15px;
        }
        
        .print-button {
            text-align: center;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 2px solid #ecf0f1;
        }
        
        .print-button button {
            padding: 10px 30px;
            background-color: #3498db;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 14px;
            cursor: pointer;
            margin-right: 10px;
        }
        
        .print-button button:hover {
            background-color: #2980b9;
        }
        
        .print-button .back-btn {
            background-color: #95a5a6;
        }
        
        .print-button .back-btn:hover {
            background-color: #7f8c8d;
        }
        
        @media print {
            body {
                background: white;
                padding: 0;
            }
            
            .invoice-container {
                box-shadow: none;
                width: 100%;
                height: 100%;
            }
            
            .print-button {
                display: none;
            }
        }
        
        @page {
            size: A4;
            margin: 0;
        }
    </style>
</head>
<body data-invoice-filename="Payment_Invoice_<%= student.userId.name.trim().replace(/\s+/g, '_') %>_<%= payment.month.trim().replace(/\s+/g, '_') %>_<%= moment().format('YYYY-MM-DD') %>">
    <div class="invoice-container">
        <!-- Header -->
        <div class="header">
            <h1>PAYMENT INVOICE</h1>
            <p>Payment Receipt & Confirmation</p>
        </div>
        
        <!-- Invoice Number -->
        <div class="invoice-number">
            <p><strong>Invoice No:</strong></p>
            <p class="number"><%= invoiceNumber %></p>
            <p><strong>Date:</strong></p>
            <p class="number"><%= moment().format('MMM DD, YYYY') %></p>
        </div>
        
        <!-- Student Information -->
        <div class="student-info">
            <h3>Student Information</h3>
            <div class="info-row">
                <div class="info-item">
                    <label>Name:</label>
                    <span><%= student.userId.name %></span>
                </div>
                <div class="info-item">
                    <label>Class:</label>
                    <span><%= student.classId ? student.classId.name : 'N/A' %></span>
                </div>
            </div>
            <div class="info-row">
                <div class="info-item">
                    <label>Roll Number:</label>
                    <span><%= student.rollNo %></span>
                </div>
                <div class="info-item">
                    <label>Email:</label>
                    <span><%= student.userId.email %></span>
                </div>
            </div>
        </div>
        
        <!-- Payment Details -->
        <div class="payment-details">
            <h3>✓ Payment Successful</h3>
            <div class="detail-table">
                <div class="detail-row">
                    <label>Payment For Month:</label>
                    <span><%= payment.month %></span>
                </div>
                <div class="detail-row">
                    <label>Payment Amount:</label>
                    <span><%= payment.amount %></span>
                </div>
                <div class="detail-row">
                    <label>Payment Date:</label>
                    <span><%= moment(payment.date).format('MMM DD, YYYY') %></span>
                </div>
                <% if (payment.description) { %>
                    <div class="detail-row">
                        <label>Description:</label>
                        <span><%= payment.description %></span>
                    </div>
                <% } %>
                <div class="detail-row total">
                    <label>Total Paid:</label>
                    <span><%= payment.amount %></span>
                </div>
            </div>
        </div>
        
        <!-- Success Message -->
        <div class="success-message">
            <div class="icon">✓</div>
            <h2>Payment Confirmed</h2>
            <p>Your payment has been successfully recorded. Please keep this invoice for your records.</p>
        </div>
        
        <!-- Footer -->
        <div class="footer">
            <p>Thank you for your payment. For any queries, please contact the school administration.</p>
            <p>This is an automated receipt. No signature required.</p>
        </div>
        
        <!-- Print Buttons -->
        <div class="print-button">
            <button onclick="window.print()" class="print-now">🖨️ Print Invoice</button>
            <button class="back-btn" onclick="window.history.back()">← Back</button>
        </div>
    </div>

    <script>
        // Set document title and trigger print with meaningful filename
        function initiatePrint() {
            // Get filename from data attribute
            const filename = document.body.getAttribute('data-invoice-filename');
            
            if (filename) {
                // Set the document title - this becomes the default filename in print dialog
                document.title = filename;
            }
            
            // Trigger print dialog
            window.print();
        }
        
        // Auto-trigger print after page fully loads
        window.addEventListener('load', function() {
            setTimeout(initiatePrint, 500);
        });
    </script>