<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h3 class="mb-1">Attendance Overview</h3>
        <p class="text-muted mb-0">Track class-wise attendance records by date.</p>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="GET" action="/admin/attendance" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Class</label>
                <select name="classId" class="form-select">
                    <option value="">All Classes</option>
                    <% classes.forEach((classItem) => { %>
                        <option value="<%= classItem._id %>" <%= selectedClassId && String(selectedClassId) === String(classItem._id) ? 'selected' : '' %>>
                            <%= classItem.name %>
                        </option>
                    <% }) %>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Date</label>
                <input type="date" name="date" class="form-control" value="<%= selectedDate %>">
            </div>
            <div class="col-md-4">
                <button class="btn btn-primary" type="submit">Filter</button>
                <a href="/admin/attendance" class="btn btn-outline-secondary ms-2">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white">
        <h5 class="mb-0">Attendance Records</h5>
    </div>
    <div class="card-body p-0">
        <% if (attendanceRows && attendanceRows.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Class</th>
                            <th>Total</th>
                            <th>Present</th>
                            <th>Absent</th>
                            <th>Percentage</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% attendanceRows.forEach((row) => { %>
                            <tr>
                                <td><%= moment(row.record.date).format('DD MMM, YYYY') %></td>
                                <td><%= row.record.classId?.name || '-' %></td>
                                <td><%= row.total %></td>
                                <td class="text-success"><%= row.present %></td>
                                <td class="text-danger"><%= row.absent %></td>
                                <td><strong><%= row.percentage %>%</strong></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="p-3 text-muted">No attendance records found for the selected filter.</div>
        <% } %>
    </div>
</div>
