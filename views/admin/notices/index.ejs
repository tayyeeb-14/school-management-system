<h3 class="mb-4">Manage Notices</h3>
<div class="mb-3">
    <a href="/admin/notices/new" class="btn btn-primary">Add New Notice</a>
</div>
<div class="list-group">
    <% if (notices && notices.length > 0) { %>
        <% notices.forEach(n => { %>
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-1"><%= n.title %></h5>
                    <p class="mb-1 text-muted"><%= n.description %></p>
                    <small class="text-muted">For: <%= n.forClass || 'All' %> • <%= moment(n.date).fromNow() %></small>
                </div>
                <div>
                    <a href="/admin/notices/<%= n._id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form action="/admin/notices/<%= n._id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this notice?')">
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div class="list-group-item text-center text-muted">No notices found</div>
    <% } %>
</div>
