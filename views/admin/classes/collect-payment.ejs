<%
const resolvedSuggestedAmount = typeof suggestedAmount !== 'undefined' ? Number(suggestedAmount || 0) : 0;
const resolvedMonthOptions = (typeof monthOptions !== 'undefined' && Array.isArray(monthOptions)) ? monthOptions : [];
const resolvedStudents = (typeof students !== 'undefined' && Array.isArray(students)) ? students : [];
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
        <h3 class="mb-1">Class Fee Action - <%= classDoc.name %></h3>
        <p class="text-muted mb-0">Select students, choose the month, and either record a payment or create an unpaid due.</p>
    </div>
    <a href="/admin/classes/fees" class="btn btn-secondary">Back to Classes</a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <!-- Visible debug badge for script status -->
        <div id="collectDebugBadge" style="position:fixed;top:80px;right:24px;z-index:1050;background:#0d6efd;color:#fff;padding:6px 10px;border-radius:6px;box-shadow:0 2px 6px rgba(0,0,0,0.2);font-size:13px;">
            Fees Script: <span id="collectDebugStatus">loading...</span>
            <div style="font-size:11px;margin-top:4px">Selected: <span id="collectDebugCount">0</span></div>
            <div id="collectDebugError" style="display:none;background:#fff;color:#900;padding:6px;border-radius:4px;margin-top:6px;font-size:11px;"></div>
        </div>
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Class Overview</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <small class="text-muted d-block">Class Name</small>
                        <strong><%= classDoc.name %></strong>
                    </div>
                    <div class="col-md-4">
                        <small class="text-muted d-block">Students</small>
                        <strong><%= resolvedStudents.length %></strong>
                    </div>
                    <div class="col-md-4">
                        <small class="text-muted d-block">Suggested Monthly Amount</small>
                        <strong><%= resolvedSuggestedAmount.toFixed(2) %></strong>
                    </div>
                </div>
            </div>
        </div>

        <form action="/admin/classes/<%= classDoc._id %>/fees/collect-payment" method="POST" id="collectPaymentForm">
            <div class="card">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Select Students</h5>
                    <div class="form-check form-check-inline mb-0">
                        <input type="checkbox" id="selectAllStudents" class="form-check-input" onchange="(function(cb){const all=document.querySelectorAll('.student-checkbox');all.forEach(i=>i.checked=cb.checked);const selectedCount=document.querySelectorAll('.student-checkbox:checked').length;var sc=document.getElementById('selectedCount');if(sc)sc.textContent=selectedCount;var ssc=document.getElementById('selectedStudentsCalc');if(ssc)ssc.textContent=selectedCount;var amountEl=document.getElementById('amountInput');var amount=parseFloat(amountEl?amountEl.value||0:0)||0;var ac=document.getElementById('amountCalc');if(ac)ac.textContent=amount.toFixed(2);var tc=document.getElementById('totalCalc');if(tc)tc.textContent=(selectedCount*amount).toFixed(2);var cbn=document.getElementById('collectBtn');if(cbn)cbn.disabled=(selectedCount===0||amount===0);})(this)">
                        <label class="form-check-label text-white" for="selectAllStudents">Select All</label>
                    </div>
                </div>
                <div class="card-body">
                    <% if (resolvedStudents.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 52px;"></th>
                                        <th>Roll No</th>
                                        <th>Student</th>
                                        <th>Email</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% resolvedStudents.forEach((student) => { %>
                                        <tr>
                                            <td>
                                                <input type="checkbox" name="selectedStudents[]" value="<%= student._id %>" class="form-check-input student-checkbox" onchange="(function(cb){const selectedCount=document.querySelectorAll('.student-checkbox:checked').length;const amountEl=document.getElementById('amountInput');const amount=parseFloat(amountEl?amountEl.value||0:0)||0;const total=(selectedCount*amount).toFixed(2);var sc=document.getElementById('selectedCount');if(sc)sc.textContent=selectedCount;var ssc=document.getElementById('selectedStudentsCalc');if(ssc)ssc.textContent=selectedCount;var ac=document.getElementById('amountCalc');if(ac)ac.textContent=amount.toFixed(2);var tc=document.getElementById('totalCalc');if(tc)tc.textContent=total;var cbn=document.getElementById('collectBtn');if(cbn)cbn.disabled=(selectedCount===0||amount===0);})(this)">
                                            </td>
                                            <td><strong><%= student.rollNo %></strong></td>
                                            <td><%= student.userId.name %></td>
                                            <td><small><%= student.userId.email %></small></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>

                        <div class="alert alert-info mb-0">
                            <strong>Selected:</strong> <span id="selectedCount">0</span> / <%= resolvedStudents.length %> students
                        </div>
                    <% } else { %>
                        <div class="alert alert-warning mb-0">No students are currently assigned to this class.</div>
                    <% } %>
                </div>
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div class="card sticky-top" style="top: 20px;">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Payment / Due Setup</h5>
            </div>
            <div class="card-body">
                <% if (resolvedStudents.length > 0) { %>
                    <div class="mb-3">
                        <label class="form-label">Month</label>
                        <select name="month" form="collectPaymentForm" class="form-select" required>
                            <option value="">Choose month</option>
                            <% resolvedMonthOptions.forEach((month) => { %>
                                <option value="<%= month %>"><%= month %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Amount Per Student</label>
                        <input
                            type="number"
                            step="0.01"
                            min="0"
                            name="amountPerStudent"
                            form="collectPaymentForm"
                            class="form-control"
                            id="amountInput"
                            value="<%= resolvedSuggestedAmount.toFixed(2) %>"
                            placeholder="0.00"
                            required
                            onchange="(function(){const selectedCount=document.querySelectorAll('.student-checkbox:checked').length;var amount=parseFloat(this.value||0)||0;var ac=document.getElementById('amountCalc');if(ac)ac.textContent=amount.toFixed(2);var tc=document.getElementById('totalCalc');if(tc)tc.textContent=(selectedCount*amount).toFixed(2);var cbn=document.getElementById('collectBtn');if(cbn)cbn.disabled=(selectedCount===0||amount===0);var ssc=document.getElementById('selectedStudentsCalc');if(ssc)ssc.textContent=selectedCount;var sc=document.getElementById('selectedCount');if(sc)sc.textContent=selectedCount;})()"
                        >
                        <small class="text-muted">Used as payment amount, or as due amount when creating unpaid dues only.</small>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input type="checkbox" class="form-check-input" id="createDueOnly" name="isOverdue" form="collectPaymentForm">
                        <label class="form-check-label" for="createDueOnly">
                            Create due only (do not record payment)
                        </label>
                    </div>

                    <div class="alert alert-secondary mb-3" id="modeHelp">
                        <strong>Mode:</strong> Payment collection.<br>
                        Selected students will receive a payment entry for the chosen month.
                    </div>

                    <div class="alert alert-info mb-3">
                        <strong>Calculation</strong><br>
                        Students: <strong id="selectedStudentsCalc">0</strong><br>
                        Amount / Student: <strong id="amountCalc">0.00</strong><br>
                        <hr class="my-2">
                        Total Action Value: <strong id="totalCalc">0.00</strong>
                    </div>

                    <button type="submit" class="btn btn-success w-100" id="collectBtn" form="collectPaymentForm" disabled>
                        <i class="fas fa-check-circle me-1"></i> Save Class Action
                    </button>
                <% } else { %>
                    <div class="alert alert-danger mb-0">This class has no students, so no fee action can be created.</div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script src="/js/collect-payment.js"></script>
