<h3 class="mb-4">Class Fee Management</h3>

<div class="mb-3">
    <a href="/admin/dashboard" class="btn btn-secondary">Back to Dashboard</a>
</div>

<% if (classesWithFees && classesWithFees.length > 0) { %>
    <div class="row">
        <% classesWithFees.forEach(cls => { %>
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header">
                        <h5 class="mb-0"><%= cls.name %></h5>
                    </div>
                    <div class="card-body">
                        <% if (cls.classFee && cls.classFee.fees && cls.classFee.fees.length > 0) { %>
                            <p><strong>Monthly Total:</strong> <%= cls.classFee.totalMonthlyFee %></p>
                            <h6>Fee Breakdown:</h6>
                            <ul class="list-group mb-3">
                                <% cls.classFee.fees.forEach(fee => { %>
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong><%= fee.name %></strong>
                                            <br>
                                            <small class="text-muted"><%= fee.amount %> - <%= fee.frequency %></small>
                                        </div>
                                    </li>
                                <% }); %>
                            </ul>
                        <% } else { %>
                            <div class="alert alert-warning mb-3">
                                No fees defined yet for this class.
                            </div>
                        <% } %>
                        <div class="d-flex gap-2">
                            <a href="/admin/classes/<%= cls._id %>/fees/edit" class="btn btn-primary btn-sm">
                                <i class="fas fa-edit"></i> Manage Fees
                            </a>
                            <a href="/admin/classes/<%= cls._id %>/fees/collect-payment" class="btn btn-success btn-sm">
                                <i class="fas fa-money-bill"></i> Class Action
                            </a>
                            <a href="/admin/classes/<%= cls._id %>/fees/payment-history" class="btn btn-info btn-sm">
                                <i class="fas fa-history"></i> History
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
<% } else { %>
    <div class="alert alert-info">No classes found in the system.</div>
<% } %>
