<h3 class="mb-4">Edit Class Fees - <%= classDoc.name %></h3>

<div class="mb-3">
    <a href="/admin/classes/fees" class="btn btn-secondary">Back to Classes</a>
</div>

<!-- Current Fees -->
<div class="card mb-4">
    <div class="card-header">
        <h5>Current Fee Structure</h5>
    </div>
    <div class="card-body">
        <% if (classFee.fees && classFee.fees.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Fee Type</th>
                            <th>Amount</th>
                            <th>Frequency</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% classFee.fees.forEach(fee => { %>
                            <tr>
                                <td><%= fee.name %></td>
                                <td><strong><%= fee.amount %></strong></td>
                                <td><span class="badge bg-info"><%= fee.frequency %></span></td>
                                <td>
                                    <form action="/admin/classes/<%= classDoc._id %>/fees/<%= fee._id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this fee type?')">
                                        <input type="hidden" name="_method" value="DELETE">
                                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <div class="mt-3 p-3 bg-light">
                <h6>Total Monthly Fee: <strong><%= classFee.totalMonthlyFee %></strong></h6>
            </div>
        <% } else { %>
            <p class="text-muted">No fees defined yet for this class.</p>
        <% } %>
    </div>
</div>

<!-- Add New Fee Type -->
<div class="card">
    <div class="card-header">
        <h5>Add New Fee Type</h5>
    </div>
    <div class="card-body">
        <form action="/admin/classes/<%= classDoc._id %>/fees/add-fee" method="POST">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Fee Type Name</label>
                    <input type="text" name="name" class="form-control" placeholder="e.g., Tuition Fee, Transport Fee, Lab Fee" required>
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Amount</label>
                    <input type="number" step="0.01" name="amount" class="form-control" placeholder="Amount" required>
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Frequency</label>
                    <select name="frequency" class="form-select" required>
                        <option value="monthly">Monthly</option>
                        <option value="quarterly">Quarterly</option>
                        <option value="yearly">Yearly</option>
                    </select>
                </div>
            </div>
            <button type="submit" class="btn btn-success">Add Fee Type</button>
        </form>
    </div>
</div>

<div class="mt-4">
    <p class="text-muted">
        <strong>Note:</strong> This fee structure becomes the default monthly amount for students in this class
        when admins create dues or record payments. You can add multiple fee types like tuition, transport,
        exam fees, and more.
    </p>
</div>
