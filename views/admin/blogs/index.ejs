<h3 class="mb-4">Manage Blog Posts</h3>
<div class="mb-3">
    <a href="/admin/blogs/new" class="btn btn-primary">Add New Post</a>
</div>
<div class="row g-4">
    <% if (blogs && blogs.length > 0) { %>
        <% blogs.forEach(post => { %>
            <div class="col-md-4">
                <div class="card h-100">
                    <% if (post.image) { %>
                        <img src="/uploads/images/<%= post.image %>" class="card-img-top" alt="<%= post.title %>">
                    <% } %>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title"><%= post.title %></h5>
                        <p class="card-text text-muted small mb-2">By <%= post.author?.name || 'Unknown' %></p>
                        <p class="card-text flex-grow-1"><%= (post.content || '').substring(0, 120) %>...</p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <a href="/admin/blogs/<%= post._id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <form action="/admin/blogs/<%= post._id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this post?')">
                                <input type="hidden" name="_method" value="DELETE">
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div class="col-12 text-center text-muted">No blog posts found</div>
    <% } %>
</div>
