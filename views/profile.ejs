<%- contentFor('body') %>

<div class="container">
    <div class="row">
        <div class="col-md-4">
            <div class="card profile-card text-center mb-4">
                <div class="profile-header">
                    <% const profileAvatar = (user && user.photo && user.photo !== 'default.jpg') ? ('/uploads/images/' + user.photo) : '/img/testimonial1.jpg'; %>
                    <img src="<%= profileAvatar %>" class="profile-img rounded-circle" alt="Profile">
                    <h4 class="mt-2"><%= user.name %></h4>
                    <p class="text-muted mb-0"><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></p>
                </div>
                <div class="card-body">
                    <p><strong>Username:</strong> <%= user.username %></p>
                    <p><strong>Email:</strong> <%= user.email %></p>
                    <p><strong>Phone:</strong> <%= user.phone || '-' %></p>
                    <p><strong>Joined:</strong> <%= moment(user.createdAt).format('MMM DD, YYYY') %></p>
                    <a href="/" class="btn btn-secondary mt-2">Back to Home</a>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Profile Details</h5>
                </div>
                <div class="card-body">
                    <% if (user.role === 'student' && roleData) { %>
                        <h6>Student Details</h6>
                        <p><strong>Class:</strong> <%= roleData.classId ? roleData.classId.name : 'N/A' %></p>
                        <p><strong>Roll No:</strong> <%= roleData.rollNo %></p>
                        <p><strong>Father Name:</strong> <%= roleData.fatherName || '-' %></p>
                        <p><strong>Subjects:</strong> <%= roleData.subjects && roleData.subjects.length ? roleData.subjects.join(', ') : '-' %></p>
                        <p><strong>Attendance %:</strong> <%= roleData.attendance ? Math.round((roleData.attendance.filter(a => a.status === 'present').length / (roleData.attendance.length || 1)) * 100) : 0 %>%</p>

                        <h6 class="mt-3">Marks</h6>
                        <% if (roleData.marks && roleData.marks.length) { %>
                            <table class="table table-sm">
                                <thead>
                                    <tr><th>Subject</th><th>Marks</th><th>Out Of</th><th>Date</th></tr>
                                </thead>
                                <tbody>
                                    <% roleData.marks.forEach(m => { %>
                                        <tr>
                                            <td><%= m.subject %></td>
                                            <td><%= m.marks %></td>
                                            <td><%= m.outOf %></td>
                                            <td><%= moment(m.date).format('MMM DD, YYYY') %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        <% } else { %>
                            <p class="text-muted">No marks available.</p>
                        <% } %>

                    <% } else if (user.role === 'teacher' && roleData) { %>
                        <h6>Teacher Details</h6>
                        <p><strong>Subject:</strong> <%= roleData.subject || '-' %></p>
                        <p><strong>Classes:</strong> <%= roleData.classIds && roleData.classIds.length ? roleData.classIds.map(c => c.name).join(', ') : '-' %></p>
                        <p><strong>Qualifications:</strong> <%= roleData.qualifications || '-' %></p>

                        <h6 class="mt-3">Assigned Classes</h6>
                        <% if (roleData.classes && roleData.classes.length) { %>
                            <p><%= roleData.classes.join(', ') %></p>
                        <% } else { %>
                            <p class="text-muted">No classes assigned.</p>
                        <% } %>

                    <% } else { %>
                        <p class="text-muted">No additional profile details available for this user.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>
