<%
const heroSlides = [
    { src: '/img/1.jpg', alt: 'Students learning in a bright classroom' },
    { src: '/img/2.jpg', alt: 'School campus and student life' },
    { src: '/img/3.jpg', alt: 'Safe and welcoming campus environment' },
    { src: '/img/4.jpg', alt: 'Students building confidence through activities' },
    { src: '/img/5.jpg', alt: 'Admissions and future-ready learning spaces' }
];

const programCards = [
    {
        icon: 'fa-seedling',
        title: 'Primary',
        detail: 'Classes I to V',
        copy: 'Strong foundations in literacy, numeracy, confidence, and curiosity through joyful structured learning.'
    },
    {
        icon: 'fa-book-open-reader',
        title: 'Secondary',
        detail: 'Classes VI to X',
        copy: 'Deeper subject mastery, critical thinking, and disciplined preparation for exams and future opportunities.'
    },
    {
        icon: 'fa-microscope',
        title: 'Senior Secondary',
        detail: 'Classes XI to XII',
        copy: 'Advanced academics, stream-focused mentoring, and career guidance built around ambition and clarity.'
    },
    {
        icon: 'fa-trophy',
        title: 'Co-curricular',
        detail: 'Sports, arts, clubs',
        copy: 'Leadership, creativity, teamwork, and self-expression that support the whole child beyond academics.'
    }
];

const schoolHighlights = [
    {
        icon: 'fa-chalkboard-user',
        title: 'Experienced Faculty',
        copy: 'Dedicated, qualified teachers who focus on personalised learning and student growth.'
    },
    {
        icon: 'fa-laptop-code',
        title: 'Smart Classrooms',
        copy: 'Technology-enabled spaces with interactive teaching aids that keep lessons engaging and effective.'
    },
    {
        icon: 'fa-shield-halved',
        title: 'Safe Campus Culture',
        copy: 'A structured, secure environment that prioritises wellbeing, discipline, and confidence every day.'
    },
    {
        icon: 'fa-people-group',
        title: 'Holistic Development',
        copy: 'Sports, clubs, performances, and leadership opportunities that nurture balanced, capable students.'
    }
];

const platformBenefits = [
    {
        icon: 'fa-graduation-cap',
        title: 'Educator-centric design',
        copy: 'Developed around real school workflows so administrators and teachers can focus on impact, not friction.'
    },
    {
        icon: 'fa-mobile-screen-button',
        title: 'Mobile-first experience',
        copy: 'Parents, teachers, and students stay connected across phones, tablets, and desktops with ease.'
    },
    {
        icon: 'fa-headset',
        title: 'Dedicated support',
        copy: 'Implementation guidance, onboarding help, and day-to-day support that keeps adoption smooth.'
    },
    {
        icon: 'fa-gears',
        title: 'Easy integration',
        copy: 'Flexible processes and practical migration paths that fit the way schools already operate.'
    },
    {
        icon: 'fa-chart-line',
        title: 'Proven results',
        copy: 'Better communication, stronger accountability, and less administrative overhead across the campus.'
    },
    {
        icon: 'fa-sack-dollar',
        title: 'Transparent value',
        copy: 'Clear outcomes, sensible cost efficiency, and visible returns through better school operations.'
    }
];

const successStories = [
    {
        initials: 'DR',
        name: 'Dr. Rajesh Kumar',
        role: 'Principal, City High School',
        quote: 'This platform has revolutionized how we communicate with parents. Attendance tracking and fee management alone saved us 15 hours per week.'
    },
    {
        initials: 'MP',
        name: 'Ms. Priya Sharma',
        role: 'Teacher, Delhi Public School',
        quote: 'Students love the digital classroom experience. Assignment submission and faster feedback have improved engagement and performance.'
    },
    {
        initials: 'AP',
        name: 'Amit Patel',
        role: 'Parent, Mumbai Academy',
        quote: 'We receive timely updates about progress and behaviour. The transparency and communication have been a real advantage for our family.'
    }
];

const trustMetrics = [
    {
        value: parseInt(stats.students || 1200, 10),
        suffix: '+',
        label: 'Students thriving',
        copy: 'A vibrant learning community shaped by strong academics and personal growth.'
    },
    {
        value: parseInt(stats.teachers || 85, 10),
        suffix: '',
        label: 'Qualified teachers',
        copy: 'Experienced educators bringing consistency, care, and subject depth to every classroom.'
    },
    {
        value: parseInt(stats.classes || 45, 10),
        suffix: '',
        label: 'Active classes',
        copy: 'Structured teaching groups designed to support focus, progression, and student attention.'
    },
    {
        value: parseInt(stats.activities || 25, 10),
        suffix: '+',
        label: 'Clubs and activities',
        copy: 'A richer school life through sports, arts, leadership, and co-curricular experiences.'
    }
];

const latestNotices = Array.isArray(notices) ? notices.slice(0, 3) : [];
const featuredBlogs = Array.isArray(blogs) ? blogs.slice(0, 3) : [];
%>

<div class="home-page">
    <section class="home-page__hero home-bleed" aria-label="Homepage hero">
        <div id="homeHeroCarousel" class="carousel slide home-carousel" data-bs-ride="carousel" data-bs-interval="5600">
            <div class="carousel-indicators home-carousel-indicators">
                <% heroSlides.forEach((slide, index) => { %>
                    <button
                        type="button"
                        data-bs-target="#homeHeroCarousel"
                        data-bs-slide-to="<%= index %>"
                        class="<%= index === 0 ? 'active' : '' %>"
                        aria-current="<%= index === 0 ? 'true' : 'false' %>"
                        aria-label="Slide <%= index + 1 %>"></button>
                <% }); %>
            </div>

            <div class="carousel-inner">
                <% heroSlides.forEach((slide, index) => { %>
                    <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                        <img src="<%= slide.src %>" class="home-carousel-image" alt="<%= slide.alt %>">
                    </div>
                <% }); %>
            </div>

            <button class="carousel-control-prev home-carousel-control" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next home-carousel-control" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>

            <div class="home-hero-overlay" aria-hidden="true"></div>
            <div class="home-hero-glow home-hero-glow--one" aria-hidden="true"></div>
            <div class="home-hero-glow home-hero-glow--two" aria-hidden="true"></div>

            <div class="home-hero-shell">
                <div class="container">
                    <div class="home-hero-grid">
                        <div class="home-hero-copy home-reveal">
                            <span class="section-eyebrow section-eyebrow--light">Modern learning, strong values, and confident futures</span>
                            <h1 class="home-hero-title">Inspiring excellence in education with a campus experience families trust.</h1>
                            <p class="home-hero-text">
                                A premium school experience focused on strong academics, character building, safety,
                                and all-round development from the early years through senior secondary.
                            </p>

                            <div class="home-hero-actions">
                                <a href="/auth/register" class="home-btn home-btn--primary">Start Registration</a>
                                <a href="#programs" class="home-btn home-btn--ghost">Explore Programs</a>
                            </div>

                            <div class="home-proof-chips" aria-label="School highlights">
                                <span class="home-proof-chip">Affiliated school</span>
                                <span class="home-proof-chip">Nursery to Grade XII</span>
                                <span class="home-proof-chip">Parent-friendly communication</span>
                            </div>
                        </div>

                        <div class="home-hero-stack">
                            <aside class="home-panel home-panel--glass home-reveal" style="--delay: 0.12s;">
                                <div class="home-panel-head">
                                    <span class="home-panel-kicker">Admissions 2026-27</span>
                                    <h2>Limited seats open for the upcoming academic session.</h2>
                                </div>
                                <p>
                                    Schedule a campus visit, speak with admissions, and explore the right programme
                                    for your child with clarity and confidence.
                                </p>

                                <div class="home-mini-metrics">
                                    <div>
                                        <strong><%= stats.classes %></strong>
                                        <span>Classes</span>
                                    </div>
                                    <div>
                                        <strong><%= stats.activities %>+</strong>
                                        <span>Activities</span>
                                    </div>
                                    <div>
                                        <strong><%= stats.teachers %></strong>
                                        <span>Teachers</span>
                                    </div>
                                </div>

                                <a href="/contact" class="home-inline-link">
                                    Book a campus visit
                                    <i class="fas fa-arrow-right"></i>
                                </a>
                            </aside>

                            <aside class="home-panel home-panel--solid home-reveal" style="--delay: 0.24s;">
                                <div class="home-panel-head">
                                    <span class="home-panel-kicker">Latest notices</span>
                                    <h2>Stay updated with what matters this week.</h2>
                                </div>

                                <% if (latestNotices.length) { %>
                                    <ul class="home-notice-list">
                                        <% latestNotices.forEach((noticeItem) => { %>
                                            <li>
                                                <div class="home-notice-meta">
                                                    <span class="home-notice-tag"><%= noticeItem.category || 'general' %></span>
                                                    <span><%= moment(noticeItem.date).format('DD MMM YYYY') %></span>
                                                </div>
                                                <strong><%= noticeItem.title %></strong>
                                                <p><%= noticeItem.description ? noticeItem.description.substring(0, 96) : 'Important school update for students and parents.' %></p>
                                            </li>
                                        <% }); %>
                                    </ul>
                                <% } else { %>
                                    <div class="home-empty-state">
                                        <strong>Fresh announcements will appear here.</strong>
                                        <p>Once notices are published, families can quickly review key dates and updates from the homepage.</p>
                                    </div>
                                <% } %>
                            </aside>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-metrics home-bleed" aria-label="School metrics">
        <div class="container">
            <div class="home-metric-grid">
                <% trustMetrics.forEach((metric, index) => { %>
                    <article class="home-metric-card home-reveal" style="--delay: <%= 0.08 * (index + 1) %>s;">
                        <div class="home-metric-value">
                            <span class="home-counter" data-counter="<%= metric.value %>">0</span><span><%= metric.suffix %></span>
                        </div>
                        <h3><%= metric.label %></h3>
                        <p><%= metric.copy %></p>
                    </article>
                <% }); %>
            </div>
        </div>
    </section>

    <section id="programs" class="home-section home-section--soft home-bleed">
        <div class="container">
            <div class="home-section-head">
                <span class="section-eyebrow">Academic pathways</span>
                <h2 class="section-heading">Comprehensive programmes designed for every stage of the student journey.</h2>
                <p class="section-copy">
                    From foundational learning to advanced subject preparation, each programme is structured to build
                    confidence, curiosity, and long-term success.
                </p>
            </div>

            <div class="home-program-grid">
                <% programCards.forEach((program, index) => { %>
                    <article class="home-program-card home-reveal" style="--delay: <%= 0.08 * (index + 1) %>s;">
                        <div class="home-program-icon">
                            <i class="fas <%= program.icon %>"></i>
                        </div>
                        <div class="home-program-detail"><%= program.detail %></div>
                        <h3><%= program.title %></h3>
                        <p><%= program.copy %></p>
                    </article>
                <% }); %>
            </div>
        </div>
    </section>

    <section class="home-admission-band home-bleed" aria-label="Admission call to action">
        <div class="container">
            <div class="home-admission-card home-reveal">
                <div>
                    <span class="section-eyebrow section-eyebrow--light">Admissions open</span>
                    <h2>Ready to give your child a confident, future-ready school experience?</h2>
                    <p>Connect with our team to understand programmes, campus culture, and the admissions process.</p>
                </div>
                <div class="home-admission-actions">
                    <a href="/auth/register" class="home-btn home-btn--light">Apply now</a>
                    <a href="/contact" class="home-btn home-btn--ghost-light">Speak to admissions</a>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section home-bleed">
        <div class="container">
            <div class="home-story-grid">
                <div class="home-story-copy">
                    <span class="section-eyebrow">Why choose our school</span>
                    <h2 class="section-heading">A school environment that balances academic ambition with care, structure, and opportunity.</h2>
                    <p class="section-copy section-copy--left">
                        Families look for more than marks alone. They want strong teaching, safe systems, inspiring
                        spaces, and a campus culture that helps children grow with confidence.
                    </p>

                    <div class="home-highlight-grid">
                        <% schoolHighlights.forEach((item, index) => { %>
                            <article class="home-highlight-card home-reveal" style="--delay: <%= 0.08 * (index + 1) %>s;">
                                <div class="home-highlight-icon">
                                    <i class="fas <%= item.icon %>"></i>
                                </div>
                                <div>
                                    <h3><%= item.title %></h3>
                                    <p><%= item.copy %></p>
                                </div>
                            </article>
                        <% }); %>
                    </div>
                </div>

                <div class="home-media-collage home-reveal" style="--delay: 0.18s;">
                    <figure class="home-media-card home-media-card--tall">
                        <img src="/img/1.jpg" alt="Learning environment inside the school">
                        <figcaption>Focused classrooms with a student-first learning atmosphere.</figcaption>
                    </figure>
                    <figure class="home-media-card">
                        <img src="/img/3.jpg" alt="Safe campus setting">
                        <figcaption>Safe, welcoming, and well-managed campus spaces.</figcaption>
                    </figure>
                    <figure class="home-media-card">
                        <img src="/img/4.jpg" alt="Students developing through activities">
                        <figcaption>Co-curricular experiences that build confidence and leadership.</figcaption>
                    </figure>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section home-section--navy home-bleed">
        <div class="container">
            <div class="home-section-head home-section-head--light">
                <span class="section-eyebrow section-eyebrow--light">Operational confidence</span>
                <h2 class="section-heading section-heading--light">Built for modern school communities that value communication, clarity, and consistency.</h2>
                <p class="section-copy section-copy--light">
                    These advantages make the experience smoother for administrators, teachers, students, and parents.
                </p>
            </div>

            <div class="home-benefit-grid">
                <% platformBenefits.forEach((benefit, index) => { %>
                    <article class="home-benefit-card home-reveal" style="--delay: <%= 0.06 * (index + 1) %>s;">
                        <div class="home-benefit-icon">
                            <i class="fas <%= benefit.icon %>"></i>
                        </div>
                        <h3><%= benefit.title %></h3>
                        <p><%= benefit.copy %></p>
                    </article>
                <% }); %>
            </div>
        </div>
    </section>

    <section class="home-section home-section--soft home-bleed">
        <div class="container">
            <div class="home-section-head">
                <span class="section-eyebrow">Success stories</span>
                <h2 class="section-heading">Trusted by administrators, teachers, and parents who value a better school experience.</h2>
                <p class="section-copy">
                    Real feedback from school communities who have seen the difference better communication and better systems can make.
                </p>
            </div>

            <div class="home-testimonial-grid">
                <% successStories.forEach((story, index) => { %>
                    <article class="home-testimonial-card home-reveal" style="--delay: <%= 0.08 * (index + 1) %>s;">
                        <div class="home-stars" aria-hidden="true">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                        </div>
                        <p class="home-testimonial-quote">"<%= story.quote %>"</p>
                        <div class="home-testimonial-meta">
                            <div class="home-avatar"><%= story.initials %></div>
                            <div>
                                <strong><%= story.name %></strong>
                                <span><%= story.role %></span>
                            </div>
                        </div>
                    </article>
                <% }); %>
            </div>
        </div>
    </section>

    <section class="home-section home-bleed">
        <div class="container">
            <div class="home-section-head">
                <span class="section-eyebrow">Insights and resources</span>
                <h2 class="section-heading">Latest updates, stories, and ideas from the school community.</h2>
                <p class="section-copy">
                    Keep parents and visitors engaged with helpful articles, campus updates, and timely resources.
                </p>
            </div>

            <% if (featuredBlogs.length) { %>
                <div class="home-blog-grid">
                    <% featuredBlogs.forEach((blog, index) => { %>
                        <article class="home-blog-card home-reveal" style="--delay: <%= 0.08 * (index + 1) %>s;">
                            <div class="home-blog-media">
                                <% if (blog.image) { %>
                                    <img src="/uploads/images/<%= blog.image %>" alt="<%= blog.title %>">
                                <% } else { %>
                                    <div class="home-blog-placeholder">
                                        <span>School insights</span>
                                    </div>
                                <% } %>
                            </div>
                            <div class="home-blog-body">
                                <div class="home-blog-meta">
                                    <span><i class="fas fa-user"></i> <%= blog.author && blog.author.name ? blog.author.name : 'School Team' %></span>
                                    <span><i class="fas fa-calendar"></i> <%= moment(blog.createdAt || blog.date).format('MMM D, YYYY') %></span>
                                </div>
                                <h3><%= blog.title %></h3>
                                <p><%= blog.content.substring(0, 130) %>...</p>
                                <a href="/blog/<%= blog._id %>" class="home-inline-link">
                                    Read article
                                    <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </article>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="home-empty-panel home-reveal">
                    <strong>No articles published yet.</strong>
                    <p>As blog posts are added, this section will become a polished content hub for families and visitors.</p>
                    <a href="/blog" class="home-inline-link">
                        Visit the blog
                        <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            <% } %>

            <div class="home-blog-actions">
                <a href="/blog" class="home-btn home-btn--secondary">View all articles</a>
            </div>
        </div>
    </section>

    <section class="home-final-cta home-bleed">
        <div class="container">
            <div class="home-final-cta-card home-reveal">
                <div class="home-final-copy">
                    <span class="section-eyebrow section-eyebrow--light">Premium, clean, and conversion-focused</span>
                    <h2>Ready to present your school with more confidence and clarity?</h2>
                    <p>
                        Create a stronger first impression, guide families toward the next step, and turn the homepage
                        into a more effective admissions and engagement tool.
                    </p>
                </div>
                <div class="home-final-actions">
                    <a href="/auth/register" class="home-btn home-btn--light">Get started</a>
                    <a href="/contact" class="home-btn home-btn--ghost-light">Schedule a conversation</a>
                </div>
            </div>
        </div>
    </section>
</div>
