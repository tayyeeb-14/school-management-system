            <p class="section-subtitle">Discover best practices, tips, and trends in modern education management</p>
        </div>
        <div class="row g-4">
            <% if (typeof blogs !=='undefined' && blogs.length> 0) { %>
                <% blogs.slice(0, 3).forEach(blog=> { %>
                    <div class="col-md-4">
                        <div class="blog-card">
                            <div class="blog-image-wrapper">
                                <% if (blog.image) { %>
                                    <img src="/uploads/images/<%= blog.image %>" class="blog-image"
                                        alt="<%= blog.title %>">
                                    <% } else { %>
                                        <div class="blog-image-placeholder"
                                            style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                        </div>
                                        <% } %>
                            </div>
                            <div class="blog-card-body">
                                <h5 class="blog-title">
                                    <%= blog.title %>
                                </h5>
                                <p class="blog-excerpt">
                                    <%= blog.content.substring(0, 100) %>...
                                </p>
                                <div class="blog-footer">
                                    <small class="blog-author"><i class="fas fa-user me-1"></i>
                                        <%= blog.author.name %>
                                    </small>
                                    <small class="blog-date"><i class="fas fa-calendar me-1"></i>
                                        <%= moment(blog.date).format('MMM D, YYYY') %>
                                    </small>
                                </div>
                                <a href="/blog/<%= blog._id %>" class="btn btn-sm btn-premium w-100 mt-3">Read Full
                                    Article</a>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                        <% } else { %>
                            <div class="col-12 text-center">
                                <p class="text-muted">Check back soon for insights and resources.</p>
                            </div>
                            <% } %>
        </div>
        <div class="text-center mt-5">
            <a href="/blog" class="btn btn-outline-primary btn-lg">View All Articles</a>
        </div>
    </div>
</section>

<!-- Final CTA Section -->
<section class="final-cta py-5"
    style="background: linear-gradient(135deg, rgba(79,70,229,0.95) 0%, rgba(67,56,202,0.95) 100%), url('https://images.unsplash.com/photo-1552664730-d307ca884978?w=1200&h=600&fit=crop') center/cover; color: white;">
    <div class="container text-center">
        <h2 class="cta-title mb-3">Ready to Transform Your School?</h2>
        <p class="cta-subtitle mb-5">Join hundreds of schools that have already modernized their management systems.</p>
        <div class="cta-buttons">
            <a href="/auth/register" class="btn btn-premium btn-lg me-3">
                <i class="fas fa-rocket me-2"></i>Start Your Free Trial
            </a>
            <a href="/contact" class="btn btn-outline-light btn-lg">
                <i class="fas fa-calendar-alt me-2"></i>Schedule a Demo
            </a>
        </div>
        <p class="mt-4 cta-footnote">✓ 14-day free trial • ✓ No credit card required • ✓ Instant setup</p>
    </div>
</section>

