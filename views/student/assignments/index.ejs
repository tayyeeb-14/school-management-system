<%- contentFor('body') %>

<div class="container">
    <h1 class="mb-4">My Assignments</h1>

    <div class="row">
        <% assignments.forEach(assignment => { %>
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title"><%= assignment.title %></h5>
                        <p class="card-text"><%= assignment.description %></p>
                        
                        <div class="mb-3">
                            <strong>Due Date:</strong>
                            <span class="<%= new Date() > assignment.dueDate ? 'text-danger' : 'text-success' %>">
                                <%= assignment.dueDate.toLocaleDateString() %>
                            </span>
                        </div>

                        <% 
                        const submitted = assignment.submissions.some(sub => sub.studentId.toString() === user.id);
                        const isLate = new Date() > assignment.dueDate;
                        %>

                        <% if (submitted) { %>
                            <div class="alert alert-success">
                                <i class="fas fa-check-circle"></i> Submitted
                                <% 
                                const submission = assignment.submissions.find(sub => sub.studentId.toString() === user.id);
                                if (submission.marks) { 
                                %>
                                    <br>
                                    <strong>Marks:</strong> <%= submission.marks %>/<%= assignment.totalMarks %>
                                <% } %>
                            </div>
                        <% } else if (isLate) { %>
                            <div class="alert alert-danger">
                                <i class="fas fa-exclamation-circle"></i> Past Due Date
                            </div>
                        <% } else { %>
                            <form action="/student/assignments/<%= assignment._id %>/submit" method="POST" enctype="multipart/form-data" class="mt-3">
                                <div class="mb-3">
                                    <label for="file" class="form-label">Upload Assignment</label>
                                    <input type="file" class="form-control" id="file" name="file" required>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-upload"></i> Submit Assignment
                                </button>
                            </form>
                        <% } %>

                        <% if (assignment.file) { %>
                            <div class="mt-3">
                                <a href="/uploads/documents/<%= assignment.file %>" class="btn btn-secondary" target="_blank">
                                    <i class="fas fa-download"></i> Download Assignment File
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>

    <% if (assignments.length === 0) { %>
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No assignments available at the moment.
        </div>
    <% } %>
</div>