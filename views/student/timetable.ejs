<%- contentFor('body') %>

<div class="container">
    <h1 class="mb-4">Class Timetable</h1>

    <div class="card">
        <div class="card-body">
            <% const days = Object.keys(timetable) %>
            
            <ul class="nav nav-tabs" id="timetableTabs" role="tablist">
                <% days.forEach((day, index) => { %>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link <%= index === 0 ? 'active' : '' %>" 
                                id="<%= day %>-tab" 
                                data-bs-toggle="tab" 
                                data-bs-target="#<%= day %>" 
                                type="button" 
                                role="tab">
                            <%= day.charAt(0).toUpperCase() + day.slice(1) %>
                        </button>
                    </li>
                <% }) %>
            </ul>

            <div class="tab-content mt-3" id="timetableContent">
                <% days.forEach((day, index) => { %>
                    <div class="tab-pane fade <%= index === 0 ? 'show active' : '' %>" 
                         id="<%= day %>" 
                         role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Time</th>
                                        <th>Subject</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% timetable[day].forEach(slot => { %>
                                        <tr>
                                            <td><%= slot.time %></td>
                                            <td><%= slot.subject %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>