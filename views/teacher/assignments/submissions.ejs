<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">Assignment Submissions</h3>
        <p class="text-muted mb-0"><strong><%= assignment.title %></strong> - <%= assignment.classId?.name || '-' %></p>
    </div>
    <a href="/teacher/assignments" class="btn btn-outline-secondary">Back</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <% if (assignment.submissions && assignment.submissions.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Submitted At</th>
                            <th>Marks</th>
                            <th>Feedback</th>
                            <th>Grade</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% assignment.submissions.forEach((submission) => { %>
                            <tr>
                                <td><%= submission.studentId?.name || '-' %></td>
                                <td><%= moment(submission.submittedAt).format('DD MMM, YYYY HH:mm') %></td>
                                <td><%= submission.marks !== null ? submission.marks : '-' %></td>
                                <td><%= submission.feedback || '-' %></td>
                                <td>
                                    <form action="/teacher/assignments/<%= assignment._id %>/grade/<%= submission._id %>" method="POST" class="d-flex gap-2">
                                        <input type="number" step="0.01" min="0" name="marks" class="form-control form-control-sm" style="max-width:120px;" value="<%= submission.marks !== null ? submission.marks : '' %>">
                                        <input type="text" name="feedback" class="form-control form-control-sm" value="<%= submission.feedback || '' %>">
                                        <button class="btn btn-sm btn-primary" type="submit">Save</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="p-3 text-muted">No submissions yet.</div>
        <% } %>
    </div>
</div>
