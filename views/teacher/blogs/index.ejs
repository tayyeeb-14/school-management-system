<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">My Blog Posts</h3>
    <a href="/teacher/blogs/new" class="btn btn-primary">New Blog Post</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <% if (blogs && blogs.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% blogs.forEach((blog) => { %>
                            <tr>
                                <td><%= blog.title %></td>
                                <td><%= blog.category || '-' %></td>
                                <td><%= moment(blog.createdAt).format('DD MMM, YYYY') %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="p-3 text-muted">No blog posts yet.</div>
        <% } %>
    </div>
</div>
