<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h3 class="mb-1">My Students</h3>
        <p class="text-muted mb-0">Class-wise student list with marks completion and result status.</p>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <% if (studentRows && studentRows.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Class</th>
                            <th>Roll No</th>
                            <th>Marks Status</th>
                            <th>Overall %</th>
                            <th>Grade</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% studentRows.forEach((row) => { %>
                            <tr>
                                <td><%= row.student.userId?.name || '-' %></td>
                                <td><%= row.student.classId?.name || '-' %></td>
                                <td><%= row.student.rollNo || '-' %></td>
                                <td>
                                    <% if (row.completion.complete) { %>
                                        <span class="badge bg-success">Complete</span>
                                    <% } else { %>
                                        <span class="badge bg-warning text-dark">
                                            Incomplete (<%= row.completion.missing.length %>)
                                        </span>
                                    <% } %>
                                </td>
                                <td><%= Number(row.finalResult.overallPercentage || 0).toFixed(2) %>%</td>
                                <td><strong><%= row.finalResult.overallGrade %></strong></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="p-3 text-muted">No students assigned to your classes yet.</div>
        <% } %>
    </div>
</div>
