<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h3 class="mb-1">My Salary</h3>
        <p class="text-muted mb-0">Monthly salary status and payment history.</p>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="GET" action="/teacher/salary" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Month</label>
                <input type="month" name="month" class="form-control" value="<%= selectedMonth %>" required>
            </div>
            <div class="col-md-8">
                <button class="btn btn-primary" type="submit">Load</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white h-100">
            <div class="card-body text-center">
                <small class="text-white-50 d-block mb-1">Base Salary</small>
                <h4 class="mb-0"><%= Number(salary.baseSalary || 0).toFixed(2) %></h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white h-100">
            <div class="card-body text-center">
                <small class="text-white-50 d-block mb-1">Paid Amount</small>
                <h4 class="mb-0"><%= Number(salary.paidAmount || 0).toFixed(2) %></h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-danger text-white h-100">
            <div class="card-body text-center">
                <small class="text-white-50 d-block mb-1">Remaining Amount</small>
                <h4 class="mb-0"><%= Number(salary.remainingAmount || 0).toFixed(2) %></h4>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Payment Entries - <%= selectedMonth %></h5>
        <span class="badge bg-light text-dark text-uppercase"><%= salary.status %></span>
    </div>
    <div class="card-body p-0">
        <% if (salary.payments && salary.payments.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Note</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% salary.payments.slice().reverse().forEach((payment) => { %>
                            <tr>
                                <td><%= moment(payment.date).format('DD MMM, YYYY') %></td>
                                <td><%= Number(payment.amount || 0).toFixed(2) %></td>
                                <td><%= payment.note || '-' %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="p-3 text-muted">No salary payments recorded for this month.</div>
        <% } %>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white">
        <h6 class="mb-0">Recent Salary Months</h6>
    </div>
    <div class="card-body p-0">
        <% if (salaryHistory && salaryHistory.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Month</th>
                            <th>Paid</th>
                            <th>Remaining</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% salaryHistory.forEach((item) => { %>
                            <tr>
                                <td><%= item.month %></td>
                                <td><%= Number(item.paidAmount || 0).toFixed(2) %></td>
                                <td><%= Number(item.remainingAmount || 0).toFixed(2) %></td>
                                <td><span class="badge bg-light text-dark text-uppercase"><%= item.status %></span></td>
                                <td class="text-end">
                                    <a href="/teacher/salary?month=<%= item.month %>" class="btn btn-sm btn-outline-primary">Open</a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="p-3 text-muted">No salary history available.</div>
        <% } %>
    </div>
</div>
