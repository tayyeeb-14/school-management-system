<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h3 class="mb-1">Teacher Dashboard</h3>
        <p class="text-muted mb-0">
            Welcome, <strong><%= teacher.userId?.name || 'Teacher' %></strong>.
        </p>
    </div>
    <div class="text-muted">
        Subject: <strong><%= teacher.subject || 'N/A' %></strong>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="card bg-primary text-white h-100">
            <div class="card-body text-center">
                <small class="text-white-50 d-block mb-1">Assigned Classes</small>
                <h4 class="mb-0"><%= stats.classes %></h4>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card bg-success text-white h-100">
            <div class="card-body text-center">
                <small class="text-white-50 d-block mb-1">Students</small>
                <h4 class="mb-0"><%= stats.students %></h4>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card bg-warning text-dark h-100">
            <div class="card-body text-center">
                <small class="text-muted d-block mb-1">Attendance Marked Today</small>
                <h4 class="mb-0"><%= stats.attendanceMarkedToday %></h4>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card bg-danger text-white h-100">
            <div class="card-body text-center">
                <small class="text-white-50 d-block mb-1">Marks Pending</small>
                <h4 class="mb-0"><%= stats.marksPendingStudents %></h4>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0">Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6 col-md-4">
                        <a href="/teacher/attendance" class="btn btn-outline-primary w-100">Mark Attendance</a>
                    </div>
                    <div class="col-6 col-md-4">
                        <a href="/teacher/marks" class="btn btn-outline-success w-100">Enter Marks</a>
                    </div>
                    <div class="col-6 col-md-4">
                        <a href="/teacher/students" class="btn btn-outline-secondary w-100">My Students</a>
                    </div>
                    <div class="col-6 col-md-4">
                        <a href="/teacher/salary" class="btn btn-outline-dark w-100">My Salary</a>
                    </div>
                    <div class="col-6 col-md-4">
                        <a href="/teacher/assignments" class="btn btn-outline-info w-100">Assignments</a>
                    </div>
                    <div class="col-6 col-md-4">
                        <a href="/teacher/blogs" class="btn btn-outline-warning w-100">My Blogs</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0">Current Month Salary</h5>
            </div>
            <div class="card-body">
                <div class="mb-2">Month: <strong><%= currentSalary.month %></strong></div>
                <div class="mb-2">Base: <strong><%= Number(currentSalary.baseSalary || 0).toFixed(2) %></strong></div>
                <div class="mb-2 text-success">Paid: <strong><%= Number(currentSalary.paidAmount || 0).toFixed(2) %></strong></div>
                <div class="mb-3 text-danger">Remaining: <strong><%= Number(currentSalary.remainingAmount || 0).toFixed(2) %></strong></div>
                <a href="/teacher/salary?month=<%= currentSalary.month %>" class="btn btn-sm btn-primary">View Salary Details</a>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white">
        <h5 class="mb-0">Recent Attendance Records</h5>
    </div>
    <div class="card-body p-0">
        <% if (recentAttendance && recentAttendance.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Class</th>
                            <th>Total Students</th>
                            <th>Present</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentAttendance.forEach((record) => { %>
                            <% const total = record.entries.length; %>
                            <% const present = record.entries.filter((entry) => entry.status === 'present').length; %>
                            <tr>
                                <td><%= moment(record.date).format('DD MMM, YYYY') %></td>
                                <td><%= record.classId?.name || '-' %></td>
                                <td><%= total %></td>
                                <td><%= present %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="p-3 text-muted">No attendance records yet.</div>
        <% } %>
    </div>
</div>
