<% /* views/blog/show.ejs - single blog post */ %>
<article class="mb-4">
    <h1 class="mb-2"><%= blog.title %></h1>
    <p class="text-muted small mb-3">
        <i class="fas fa-user me-1"></i> <%= blog.author?.name || 'Unknown' %> • <%= moment(blog.createdAt).format('LL') %>
    </p>

    <% if (blog.image) { %>
        <img src="/uploads/images/<%= blog.image %>" class="img-fluid mb-3" alt="<%= blog.title %>">
    <% } %>

    <div class="content mb-4"><%= blog.content %></div>

    <hr>

    <section id="comments">
        <h5>Comments (<%= (blog.comments || []).length %>)</h5>
        <% if (blog.comments && blog.comments.length > 0) { %>
            <% blog.comments.forEach(c => { %>
                <div class="mb-3">
                    <p class="mb-1"><strong><%= c.user?.name || 'Anonymous' %></strong> <small class="text-muted">• <%= moment(c.date).fromNow() %></small></p>
                    <p class="mb-0"><%= c.content %></p>
                </div>
            <% }); %>
        <% } else { %>
            <p class="text-muted">No comments yet.</p>
        <% } %>

        <% if (user) { %>
            <form action="/student/blog/<%= blog._id %>/comment" method="POST" class="mt-3">
                <div class="mb-2">
                    <textarea name="content" class="form-control" rows="3" placeholder="Write a comment..." required></textarea>
                </div>
                <button class="btn btn-primary" type="submit">Post Comment</button>
            </form>
        <% } else { %>
            <p class="mt-3"><a href="/auth/login">Log in</a> to comment.</p>
        <% } %>
    </section>
</article>
